{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ibex.example/schemas/proofqa-response-integrity-v0.1.schema.json",
  "title": "ProofQA Response Integrity Record v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "profile",
    "transition_id",
    "response_profile",
    "response_text",
    "response_digest",
    "claims",
    "overall_verdict",
    "verifier",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "profile": {"const": "org.ibex.response-integrity.v0.1"},
    "transition_id": {"type": "string", "minLength": 3, "maxLength": 160},
    "response_profile": {"const": "org.liminal.trustworthy-transition.response.v0.1"},
    "response_text": {"type": "string", "minLength": 1, "maxLength": 20000},
    "response_digest": {"$ref": "#/$defs/sha256Ref"},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/claim"}
    },
    "overall_verdict": {
      "enum": ["VERIFIED", "FAILED", "PARTIAL", "NOT_EVALUATED"]
    },
    "verifier": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "claim_boundary": {"type": "string", "minLength": 1, "maxLength": 2000}
  },
  "additionalProperties": false,
  "$defs": {
    "sha256Ref": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "manifestRef": {
      "type": "string",
      "pattern": "^manifest:[^#\\\\]+$"
    },
    "claim": {
      "type": "object",
      "required": [
        "claim_id",
        "claim_text",
        "claim_digest",
        "observation_refs",
        "comparison",
        "verdict",
        "reason_code"
      ],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "claim_text": {"type": "string", "minLength": 1, "maxLength": 4000},
        "claim_digest": {"$ref": "#/$defs/sha256Ref"},
        "observation_refs": {
          "type": "array",
          "items": {"$ref": "#/$defs/manifestRef"},
          "uniqueItems": true
        },
        "comparison": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": {
              "enum": ["JSON_POINTER_EQUALS", "REFERENCE_PRESENT", "OUT_OF_SCOPE"]
            },
            "pointer": {"type": "string"},
            "expected_value": {}
          },
          "additionalProperties": false
        },
        "verdict": {
          "enum": ["SUPPORTED", "CONTRADICTED", "UNVERIFIABLE", "OUT_OF_SCOPE"]
        },
        "reason_code": {"type": "string", "minLength": 1, "maxLength": 160}
      },
      "additionalProperties": false
    }
  }
}
